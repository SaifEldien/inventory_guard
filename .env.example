# Inventory Guard - Environment Configuration
# Copy this file to assets/.env and fill in your values
# ========================================================

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID_WEB=1:project:web:xxxxx
FIREBASE_APP_ID_ANDROID=1:project:android:xxxxx
FIREBASE_APP_ID_IOS=1:project:ios:xxxxx
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MEASUREMENT_ID=G-XXXXXXX
FIREBASE_IOS_BUNDLE_ID=com.example.app

# Backend API (fallback when BackendType.api is selected)
API_BASE_URL=https://api.example.com
